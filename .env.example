# Robinhood credentials (required for Journal sync)
RH_USERNAME=your_robinhood_email@example.com
RH_PASSWORD=your_robinhood_password

# Database path (default: trading_bot.db in project root)
DB_PATH=trading_bot.db

# Anthropic API key (required for Ask MyTradingBot tab)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
